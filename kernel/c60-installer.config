# C60 bootstrap-installer kernel config fragment.
#
# Inherits c60.config and only adds what the installer needs that the
# primary build doesn't:
#   - CONFIG_INITRAMFS_SOURCE: kernel/build.sh's sed rewrites this to the
#     absolute path of --initramfs-dir at build time. The literal value
#     here is a placeholder.
#   - INITRAMFS_COMPRESSION_GZIP: keep cpio small (boot_a is 48 MiB).
#
# Use:
#   kernel/build.sh ... --config=kernel/c60-installer.config \
#                       --initramfs-dir=tools/bootstrap_installer/out/rootfs
#
# Note: merge_config.sh -m takes precedence on duplicates; the c60.config
# include below means installer values win over primary defaults for
# overlapping symbols.

# Pull everything from the primary config first. If the path resolves
# relative to the build tree (it doesn't via merge_config), the user is
# expected to pass c60.config explicitly too. In practice build.sh always
# runs merge_config against this single file and the kernel's own
# defconfig as the base — so we duplicate the INITRAMFS knob explicitly
# rather than rely on includes.

# --- Embed installer initramfs ---
# Placeholder; kernel/build.sh sed-rewrites to absolute path after
# merge_config and before olddefconfig. NXP boota external-ramdisk path
# is broken on mainline DT, so we MUST embed the initramfs in Image.
CONFIG_INITRAMFS_SOURCE="tools/bootstrap_installer/out/rootfs"
CONFIG_INITRAMFS_COMPRESSION_GZIP=y
CONFIG_RD_GZIP=y
CONFIG_BLK_DEV_INITRD=y

# --- Everything else: identical to c60.config ---
# Re-declared here so merge_config can apply us standalone. The base config
# (arm64 defconfig) is the same; this layer is a superset of c60.config.

# DSA + Realtek RTL switch
CONFIG_IPV6=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=y
CONFIG_NET_DSA=y
CONFIG_NET_DSA_REALTEK=y
CONFIG_NET_DSA_REALTEK_MDIO=y
CONFIG_NET_DSA_REALTEK_RTL8365MB=y
CONFIG_NET_DSA_TAG_RTL8_4=y

# IP autoconfig
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y

# Bootloader-supplied cmdline
# CONFIG_CMDLINE_FORCE is not set
CONFIG_CMDLINE_FROM_BOOTLOADER=y

# Disk-root + partition discovery — installer mounts mmc partitions
# directly. The primary kernel needs the same; we re-state here so the
# installer config is standalone.
CONFIG_BLK_DEV=y
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_EXT4_FS=y
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_ESDHC_IMX=y

# Image size cap (same as primary)
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# CONFIG_ARCH_ACTIONS is not set
# CONFIG_ARCH_ALPINE is not set
# CONFIG_ARCH_APPLE is not set
# CONFIG_ARCH_BCM is not set
# CONFIG_ARCH_BCM2835 is not set
# CONFIG_ARCH_BCMBCA is not set
# CONFIG_ARCH_BERLIN is not set
# CONFIG_ARCH_BRCMSTB is not set
# CONFIG_ARCH_EXYNOS is not set
# CONFIG_ARCH_HISI is not set
# CONFIG_ARCH_KEEMBAY is not set
# CONFIG_ARCH_LAYERSCAPE is not set
# CONFIG_ARCH_LG1K is not set
# CONFIG_ARCH_MEDIATEK is not set
# CONFIG_ARCH_MESON is not set
# CONFIG_ARCH_NPCM is not set
# CONFIG_ARCH_QCOM is not set
# CONFIG_ARCH_REALTEK is not set
# CONFIG_ARCH_RENESAS is not set
# CONFIG_ARCH_ROCKCHIP is not set
# CONFIG_ARCH_RZG2L is not set
# CONFIG_ARCH_S32 is not set
# CONFIG_ARCH_SEATTLE is not set
# CONFIG_ARCH_SPRD is not set
# CONFIG_ARCH_STM32 is not set
# CONFIG_ARCH_SUNXI is not set
# CONFIG_ARCH_SYNQUACER is not set
# CONFIG_ARCH_TEGRA is not set
# CONFIG_ARCH_TESLA_FSD is not set
