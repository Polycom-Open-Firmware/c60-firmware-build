# C60 (Kepler proto1) — eMMC profile: Android boot.img + AVB, booted by our
# u-boot via `mmc read boot_a` + `booti`.
#
# Boot flow (after flashing slot A):
#   u-boot reads boot_a into RAM with `mmc read`, verifies it against
#   vbmeta_a, applies the dtbo_a overlay table, and boots with `booti`.
#   boot_a is an Android boot.img v0 carrying the kernel and, in its `second`
#   area, the DTB. dtbo_a holds the DTBO image; system_a holds the ext4
#   rootfs.
#
# Console: ttymxc1 = UART2 = serial header, same as stock C60.

# --- Linux kernel cmdline (baked into boot.img) ---
# root= uses the kernel-native PARTLABEL= lookup — resolved in early boot with
# no initramfs/udev — so system_a is found by its GPT label even if an LBA
# shift from re-partitioning moves it. (/dev/disk/by-partlabel/ is a udev
# symlink and does NOT exist this early; it hangs at "Waiting for root device".)
KERNEL_CMDLINE="console=tty0 console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200 panic=10 rw rootwait root=PARTLABEL=system_a"

# --- Artifact names (build.sh outputs) ---
DTB_NAME="imx8mm-kepler-proto1.dtb"
ROOTFS_IMG_NAME="rootfs.img"
ROOTFS_IMG_ZST_NAME="rootfs.img.zst"
BOOT_IMG_NAME="boot.img"
DTBO_IMG_NAME="dtbo.img"
VBMETA_IMG_NAME="vbmeta.img"

# --- Android boot.img + AVB packing knobs (consumed by bootimg/*) ---
# Load/pad addresses follow the stock C60 u-boot layout (fdt @ 0x43400000).
# booti reads the AArch64 Image header for the entry point; base 0x40000000
# plus the 0x80000 kernel offset places the kernel at 0x40080000. Pad and
# partition sizes match the stock GPT so the AVB hash-footer offset is right.
BOOT_BASE="0x40000000"
BOOT_KERNEL_OFFSET="0x00080000"   # → kernel at 0x40080000
BOOT_RAMDISK_OFFSET="0x03000000"  # → 0x43000000
BOOT_TAGS_OFFSET="0x03400000"     # → 0x43400000 (stock fdt_addr_r)
BOOT_PAGESIZE="2048"
BOOT_HEADER_VERSION="0"
BOOT_PAD_SIZE="33554432"          # 32 MiB
BOOT_PARTITION_SIZE="50331648"    # 48 MiB — stock boot_a/_b size
VBMETA_PARTITION_SIZE="1048576"   # 1 MiB — stock vbmeta_a/_b size
AVB_ALGORITHM="SHA256_RSA2048"

# --- Fastboot flash targets ---
FASTBOOT_BOOT_SLOT="boot_a"
FASTBOOT_VBMETA_SLOT="vbmeta_a"
