# C60 (Kepler proto1) — eMMC profile, mmc-read+booti path.
#
# Pivot v2: we use the TC8 "flat-layout" trick — u-boot env runs a
# `slotbboot` macro that does raw `mmc read` + `booti`, bypassing the
# Android boot.img / boota / AVB stack entirely. See FLASHING.md (TC8) for
# the original recipe; C60 differs in that we DO NOT wipe the stock GPT.
# Slot B Android remains untouched as a fallback. We only overwrite slot
# A's partitions (dtbo_a, boot_a, system_a) with raw content.
#
# Boot path (after first install):
#
#   stock u-boot → bootcmd='run slotbboot' →
#     mmc read 0x40000000 <boot_a start LBA> <boot_a size in sectors>
#     mmc read 0x43400000 <dtbo_a start LBA> <dtbo_a size in sectors>
#     booti 0x40000000 - 0x43400000
#
# Slot A's `boot_a` (48 MiB) holds the raw Image — no Android header.
# `dtbo_a` (4 MiB) holds the raw DTB.
# `system_a` (1.75 GiB) holds the raw ext4 rootfs image.
#
# slot B (boot_b / dtbo_b / system_b) is untouched: stock kernel + system.
# If anything goes wrong: `fastboot set_active b && fastboot reboot` brings
# the device back to stock Android. The `boot_slot=bak` knob in slotbboot
# falls back to slot B for raw-mmc-read mode too, but only after we've
# replaced its content — which we never do in v2.
#
# Console: ttymxc1 = UART2 = serial header on the brainslug, same as TC8
# and as stock C60 (per `01-boot-android-shell.log`).

# --- Linux kernel cmdline baked into the slotbboot macro as ${kepler_bootargs} ---
# root= uses partlabel so an LBA shift on a re-partitioned panel doesn't
# break boot. system_a is mmcblk2p5 by stock GPT — partlabel survives a
# re-pack of the partition table.
KERNEL_CMDLINE="console=tty0 console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200 keep_bootcon panic=10 rw rootwait fw_devlink=permissive root=/dev/disk/by-partlabel/system_a"

# --- Artifact names (PRIMARY outputs from build.sh) ---
# Image, DTB, rootfs.img.zst are the "tc8 trick" deliverables. boot.img +
# vbmeta below are OPTIONAL — only built when `--with-bootstrap-installer`
# is passed to build.sh (Path B one-shot installer).
DTB_NAME="imx8mm-kepler-proto1.dtb"
ROOTFS_IMG_NAME="rootfs.img"
ROOTFS_IMG_ZST_NAME="rootfs.img.zst"

# --- Bootstrap installer (Path B) artifact names ---
BOOT_IMG_NAME="boot-c60-installer.img"
VBMETA_IMG_NAME="vbmeta-c60-installer.img"

# --- u-boot env knobs (consumed by tools/install_uboot_env.sh) ---
# kepler_bootargs:  what slotbboot stuffs into bootargs before booti.
# slotbboot:        the macro itself. Uses u-boot's `part start`/`part size`
#                   commands to resolve boot_a / dtbo_a sectors from the GPT
#                   at runtime, so this env is portable across any panel
#                   whose stock GPT we leave intact.
#                   bak slot still references boot_b/dtbo_b for rollback —
#                   that only does something useful if slot B's content has
#                   also been replaced with raw mmc-read style (currently
#                   it hasn't; bak therefore boots stock Android b kernel
#                   raw, which will panic — keep boot_slot=main).
KEPLER_BOOTARGS="$KERNEL_CMDLINE"

# Load addresses match stock C60 u-boot (per
# stock-boot.log (forensic-derived, outside this repo): kernel @ 0x40480000, fdt @
# 0x43400000). booti accepts a kernel-image base and reads the AArch64
# header to pick the actual entry — 0x40000000 with a 64-byte Image header
# lands at 0x40000000+0x80000 = 0x40080000, which is below the stock
# 0x40480000 reservation, so we won't clash.
SLOTBBOOT='mmc dev 1; if test "${boot_slot}" = "bak"; then mmc read 0x40000000 ${BOOT_B_LBA} ${BOOT_LEN}; mmc read 0x43400000 ${DTBO_B_LBA} ${DTBO_LEN}; else mmc read 0x40000000 ${BOOT_A_LBA} ${BOOT_LEN}; mmc read 0x43400000 ${DTBO_A_LBA} ${DTBO_LEN}; fi; setenv bootargs "${kepler_bootargs}"; booti 0x40000000 - 0x43400000'

# --- Stock C60 GPT slot-A LBAs ---
# Probed 2026-05-13 from the live device via slug-2 UART:
#   cat /sys/class/block/mmcblk2pN/start  (in 512B sectors)
# Real values (NOT guesses anymore):
#   p1 dtbo_a    start=16384(0x4000)   size=8192(4MiB)
#   p2 dtbo_b    start=24576(0x6000)   size=8192(4MiB)
#   p3 boot_a    start=32768(0x8000)   size=98304(48MiB)
#   p4 boot_b    start=131072(0x20000) size=98304(48MiB)
#   p5 system_a  start=229376(0x38000) size=3670016(1.75GiB)
#   p6 system_b  start=3899392(0x3B8000)
#   p16 vbmeta_a start=14667776(0xDFE000) size=2048(1MiB)
#   p17 vbmeta_b start=14671872(0xDFF000)
BOOT_A_LBA="0x8000"
BOOT_B_LBA="0x20000"
DTBO_A_LBA="0x4000"
DTBO_B_LBA="0x6000"
# read length covers the whole partition; u-boot's mmc read stops at the
# requested length, so over-reading is fine as long as the buffer fits.
# boot_a is 48 MiB; reading 0x18000 sectors = 48 MiB exactly. Kernel Image
# is < 32 MiB (BOOTM_LEN cap) so the slack is wasted but safe.
BOOT_LEN="0x18000"
DTBO_LEN="0x2000"

# --- u-boot env block layout on /dev/mmcblk2 ---
# TC8 keeps its u-boot env at byte offset 0x400000, size 0x1000 (4 KiB,
# matches CONFIG_ENV_SIZE on Polycom u-boot). We ASSUME C60 mirrors this
# layout — same Polycom u-boot rev, same NXP SDK base. THIS IS UNVERIFIED.
# To check on a running stock C60:
#   dd if=/dev/mmcblk2 bs=4096 skip=1024 count=1 | xxd | head
# expect a 4-byte little-endian CRC32 followed by NUL-separated key=value
# entries (`bootcmd=...`, `bootdelay=...`, etc).
UBOOT_ENV_DEVICE="/dev/mmcblk2"
UBOOT_ENV_OFFSET="0x400000"
UBOOT_ENV_SIZE="0x1000"

# --- Bootstrap installer (Path B) boot.img + AVB knobs ---
# Only used when build.sh --with-bootstrap-installer is passed. The
# installer's job is to be flashed via `fastboot flash boot_a + vbmeta_a`
# ONCE, then on first boot its initramfs writes the real Image / DTB /
# rootfs.img to their slot-A partitions, installs the u-boot env, and
# reboots. After that, the device is on the mmc-read+booti path forever.
#
# Stock boot_a is 48 MiB; same partition gets re-flashed in the installer
# step. Pad+partition sizes match stock (so the AVB footer offset is right).
BOOT_BASE="0x40000000"
BOOT_KERNEL_OFFSET="0x00080000"   # → kernel at 0x40080000
BOOT_RAMDISK_OFFSET="0x03000000"  # → 0x43000000
BOOT_TAGS_OFFSET="0x03400000"     # → 0x43400000 (stock fdt_addr_r)
BOOT_PAGESIZE="2048"
BOOT_HEADER_VERSION="0"
BOOT_PAD_SIZE="33554432"          # 32 MiB
BOOT_PARTITION_SIZE="50331648"    # 48 MiB — stock boot_a/_b size
VBMETA_PARTITION_SIZE="1048576"   # 1 MiB — stock vbmeta_a/_b size
AVB_ALGORITHM="SHA256_RSA2048"

# --- Fastboot targets (Path B only) ---
FASTBOOT_BOOT_SLOT="boot_a"
FASTBOOT_VBMETA_SLOT="vbmeta_a"
